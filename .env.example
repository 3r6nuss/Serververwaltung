# --- 24fire Server-Verwaltung – Konfiguration -------------------------------
# Diese Datei nach ".env" kopieren und ausfüllen:  cp .env.example .env

# 24fire API-Key (Pflicht). Bleibt serverseitig, wird nie an den Browser gegeben.
FIRE_API_KEY=

# Passwort für den Zugang zum Dashboard.
# Im öffentlichen Betrieb PFLICHT. Ist es leer, ist der Login deaktiviert
# (nur für rein lokale Nutzung / SSH-Tunnel sinnvoll).
DASHBOARD_PASSWORD=

# Zufälliges Secret zum Signieren der Login-Tokens (mind. 16 Zeichen).
# Erzeugen z. B. mit:  openssl rand -hex 32
AUTH_SECRET=

# Deine (Sub-)Domain für automatisches HTTPS via Caddy.
# Beispiel: dashboard.example.com  (A-Record muss auf die Server-IP zeigen)
DOMAIN=

# Port des Node-Servers im Container (Standard 3001, i. d. R. unverändert lassen).
PORT=3001
